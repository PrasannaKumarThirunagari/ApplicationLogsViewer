@page
@{
    ViewData["Title"] = "Dashboard";
}
<div class="container-fluid p-3">
    <h4 class="mb-3"><i class="bi bi-speedometer2"></i> Log Analysis Dashboard</h4>
    <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
            <label class="form-label small">File path</label>
            <div class="input-group input-group-sm">
                <input id="dashPath" class="form-control" placeholder="C:\Logs\app.xml" />
                <button id="btn-load-dash" class="btn btn-primary">Analyze</button>
            </div>
        </div>
    </div>
    <div id="dashCards" class="row g-3 mb-3"></div>
    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <div class="card panel-card">
                <div class="card-header"><i class="bi bi-pc-display"></i> Logs by Machine</div>
                <div class="card-body"><div id="byMachine"></div></div>
            </div>
        </div>
        <div class="col-12 col-lg-6">
            <div class="card panel-card">
                <div class="card-header"><i class="bi bi-bug"></i> Top Exceptions</div>
                <div class="card-body"><div id="byException"></div></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
