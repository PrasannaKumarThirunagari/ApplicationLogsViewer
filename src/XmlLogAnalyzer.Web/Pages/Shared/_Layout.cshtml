@{
    var active = ViewData["ActiveNav"] as string ?? "";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Logs Viewer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    @* Vendored copies if available, else CDN fallback. *@
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap.min.css"
          onerror="this.onerror=null;this.href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css'" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css"
          onerror="this.onerror=null;this.href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css'" />
    <link rel="stylesheet" href="~/css/ds-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="ds-app">
    <header class="app-shell-header">
        <div class="app-shell-header-inner">
            <a class="app-brand" href="/" title="Application Logs Viewer">
                <span class="app-brand-badge" aria-hidden="true"><i class="bi bi-journal-richtext"></i></span>
                <span class="app-brand-name">Logs Viewer</span>
            </a>
            <nav class="app-primary-nav" aria-label="Primary">
                <a class="app-nav-pill @(active == "explorer" ? "is-active" : "")" href="/">
                    <i class="bi bi-folder2-open"></i><span>Explorer</span>
                </a>
                <a class="app-nav-pill @(active == "dashboard" ? "is-active" : "")" href="/Dashboard">
                    <i class="bi bi-grid-1x2"></i><span>Dashboard</span>
                </a>
            </nav>
            <div class="app-header-meta d-flex align-items-center gap-2">
                <span class="app-live-pill d-none d-md-inline" title="Read-only log inspection"><span class="live-dot"></span> Read-only</span>
                <button type="button" id="themeToggle" class="btn btn-sm app-icon-btn" title="Toggle theme" aria-label="Toggle color theme">
                    <i class="bi bi-circle-half"></i>
                </button>
            </div>
        </div>
    </header>

    <main role="main" class="app-main">
        @RenderBody()
    </main>

    <div id="toast-host" class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1080"></div>

    <script>
        (function () {
            var s = document.createElement('script');
            s.src = '/lib/bootstrap/bootstrap.bundle.min.js';
            s.onerror = function () {
                var c = document.createElement('script');
                c.src = 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js';
                document.head.appendChild(c);
            };
            document.head.appendChild(s);
        })();
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
