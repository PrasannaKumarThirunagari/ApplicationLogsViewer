@page
@model IndexModel
@{
    ViewData["Title"] = "Explorer";
    ViewData["ActiveNav"] = "explorer";
}

<div class="explorer-shell">
    <!-- LEFT: folder tree + file list -->
    <aside class="explorer-side" aria-label="Explorer navigation">
        <div class="side-section">
            <div class="side-section-label">Browse</div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-folder2-open side-icon"></i>
                <strong class="side-heading">Folders</strong>
                <button class="btn btn-sm btn-outline-secondary ms-auto" id="btn-refresh-roots" title="Refresh roots">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
            <div class="input-group input-group-sm mb-2">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input id="folderFilter" class="form-control" placeholder="Filter folders..." />
            </div>
            <div class="form-check form-switch small mb-2">
                <input class="form-check-input" type="checkbox" id="recursiveTree" />
                <label class="form-check-label" for="recursiveTree" title="When on, loading a folder includes log files from subfolders (for cache reload). The tree always shows all folders.">Include subfolders when loading folder</label>
            </div>
            <select id="rootDropdown" class="form-select form-select-sm mb-2"></select>
            <button class="btn btn-sm btn-outline-secondary w-100 mb-2" type="button" id="btn-reload-folder" disabled
                    title="Refresh caches for every log file in the selected folder">
                <i class="bi bi-arrow-clockwise"></i> Reload folder cache
            </button>
            <div class="side-tree-scroll" role="region" aria-label="Folder tree">
                <div id="folderTree" class="folder-tree"></div>
            </div>
        </div>

        <div class="side-section side-favs">
            <div class="side-section-label">Shortcuts</div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-star-fill side-icon text-warning"></i><strong class="side-heading">Favorites</strong>
            </div>
            <div class="path-list-scroll">
                <ul id="favList" class="path-list small"></ul>
            </div>
        </div>

        <div class="side-section side-recent">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-clock-history side-icon"></i><strong class="side-heading">Recently viewed</strong>
                <button type="button" class="btn btn-sm btn-outline-secondary ms-auto px-2 py-0 lh-lg" id="btn-clear-recent"
                        disabled title="Clear recently viewed files">
                    <i class="bi bi-x-lg"></i><span class="visually-hidden"> Clear recent</span>
                </button>
            </div>
            <div class="path-list-scroll">
                <ul id="recentList" class="path-list small"></ul>
            </div>
        </div>
    </aside>

    <!-- Main: log viewer only (pick files from the sidebar tree) -->
    <section class="explorer-main">
        <div class="explorer-stack">
        <div id="explorerEmpty" class="surface-card explorer-empty-hint">
            <div class="explorer-empty-hint-inner">
                <span class="toolbar-icon-wrap" aria-hidden="true"><i class="bi bi-folder2-open"></i></span>
                <p class="explorer-empty-title">No log file open</p>
                <p class="explorer-empty-sub text-secondary mb-0">Expand a folder in the sidebar and click a log file, or use Favorites / Recently viewed.</p>
            </div>
        </div>

        <!-- ====== LOG VIEWER ====== -->
        <div id="logViewer" class="surface-card log-viewer d-none">
            <header class="log-viewer-header">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="toolbar-icon-wrap" aria-hidden="true"><i class="bi bi-journal-code"></i></span>
                    <strong id="openedFile" class="text-truncate toolbar-title flex-grow-1" style="min-width:8rem"></strong>
                    <span class="ms-auto"></span>
                    <button type="button" id="btn-reload-file-header" class="btn btn-sm btn-outline-primary"
                            title="Reload this file from disk (clears server cache)">
                        <i class="bi bi-arrow-clockwise"></i> Reload file
                    </button>
                    <button type="button" id="btn-close-viewer" class="btn btn-sm btn-outline-secondary" title="Close">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <ul class="nav nav-tabs view-tabs mt-2" role="tablist">
                    <li class="nav-item"><a class="nav-link active" data-view="grid" href="#">Grid</a></li>
                    <li class="nav-item"><a class="nav-link" data-view="raw" href="#">Raw XML</a></li>
                    <li class="nav-item"><a class="nav-link" data-view="pretty" href="#">Pretty XML</a></li>
                    <li class="nav-item"><a class="nav-link" data-view="tree" href="#">Tree</a></li>
                    <li class="nav-item"><a class="nav-link" data-view="json" href="#">JSON</a></li>
                </ul>
            </header>

            <!-- Stats / dashboard strip -->
            <div class="stats-strip" id="statsStrip"></div>

            <!-- Sticky filters -->
            <div class="filters-row">
                <input id="globalSearch" class="form-control form-control-sm" placeholder="Global search (multi-keyword, case-insensitive)..." />
                <select id="severityFilter" class="form-select form-select-sm">
                    <option value="">All severity</option>
                    <option value="Error">Error</option>
                    <option value="Warning">Warning</option>
                    <option value="Info">Info</option>
                    <option value="Debug">Debug</option>
                </select>
                <input id="fromDate"      class="form-control form-control-sm" type="datetime-local" />
                <input id="toDate"        class="form-control form-control-sm" type="datetime-local" />
                <button class="btn btn-sm btn-primary" id="btn-apply-filters"><i class="bi bi-funnel-fill"></i> Apply</button>
                <button class="btn btn-sm btn-outline-secondary" id="btn-clear-filters">Clear</button>
                <button type="button" class="btn btn-sm btn-outline-primary" id="btn-reload-log"
                        title="Reload this file from disk (clears server cache and refreshes the grid)">
                    <i class="bi bi-arrow-clockwise"></i> Reload file
                </button>
            </div>

            <!-- VIEWS -->
            <div class="view-pane" id="view-grid">
                <div class="grid-wrap">
                    <table class="table table-sm log-grid">
                        <thead id="gridHead"></thead>
                        <tbody id="gridBody"></tbody>
                    </table>
                </div>
                <div class="pager">
                    <div class="small text-secondary" id="pagerInfo"></div>
                    <div class="ms-auto btn-group btn-group-sm">
                        <button class="btn btn-outline-secondary" id="btn-prev-page"><i class="bi bi-chevron-left"></i></button>
                        <button class="btn btn-outline-secondary" id="btn-next-page"><i class="bi bi-chevron-right"></i></button>
                    </div>
                    <select id="pageSize" class="form-select form-select-sm ms-2" style="width:auto">
                        <option>50</option><option selected>100</option><option>250</option>
                        <option>500</option><option>1000</option>
                    </select>
                </div>
            </div>

            <div class="view-pane d-none" id="view-raw">
                <pre class="raw-pane" id="rawPane">Select an entry from the grid to view its raw XML.</pre>
            </div>
            <div class="view-pane d-none" id="view-pretty">
                <pre class="raw-pane" id="prettyPane">Select an entry from the grid for formatted XML.</pre>
            </div>
            <div class="view-pane d-none" id="view-tree">
                <div class="raw-pane" id="treePane">Select an entry from the grid.</div>
            </div>
            <div class="view-pane d-none" id="view-json">
                <pre class="raw-pane" id="jsonPane">Select an entry from the grid for JSON.</pre>
            </div>
        </div>
        </div>
    </section>
</div>

<!-- Full log message (grid Message column is truncated with ellipsis) -->
<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="messageModalLabel">Log message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <pre class="mb-0 log-message-modal-body" id="messageModalBody"></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/explorer.js" asp-append-version="true"></script>
}
